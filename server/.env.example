# ===========================================================
#  Siam server configuration  —  COPY THIS FILE TO .env
#  cp .env.example .env   then fill in the values.
#  NEVER commit the real .env file. (.gitignore already excludes it.)
# ===========================================================

# "development" for local dev, "production" for Railway/hosting.
# In production: enables HTTPS redirect, trust proxy, combined logging.
NODE_ENV=development

# sandbox  (for testing)  |  live  (for real money)
PAYPAL_ENV=live

# --- PayPal REST app credentials (PayPal Developer > Apps & Credentials) ---
# Client ID is public. Secret is PRIVATE and lives ONLY here, never in front-end code.
PAYPAL_CLIENT_ID=PASTE_YOUR_CLIENT_ID
PAYPAL_SECRET=PASTE_YOUR_NEW_ROTATED_SECRET

# Webhook id (created in the dashboard or by setup) — enables signature verification
PAYPAL_WEBHOOK_ID=

# --- Recurring subscription plan ids (run `npm run setup-plans` to generate) ---
PLAN_MONTHLY_ID=
PLAN_YEARLY_ID=

# --- Prices (used for one-time orders & when creating plans) ---
PRICE_MONTHLY=4.99
PRICE_YEARLY=35.88
CURRENCY=USD

# --- Server ---
PORT=3000
# Comma-separated list of allowed origins for CORS (front-end URLs).
# Leave empty to allow all origins (dev only). In production, set your domain.
ALLOWED_ORIGINS=http://localhost:8000,http://localhost:3000

# Database: empty = local JSON file (dev). On Railway add a PostgreSQL plugin
# and it injects DATABASE_URL automatically.
DATABASE_URL=

# Secret for signing login (JWT) tokens — MUST be a long random string in production.
# Generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
